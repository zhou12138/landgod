# ============================================
# LandGod .gitignore
# ============================================

# Dependencies
node_modules/
**/node_modules/

# Build artifacts
out/
dist/
dist-headless/
.vite/

# Python build artifacts
**/__pycache__/
*.pyc
*.pyo
**/*.egg-info/
**/dist/*.whl
**/dist/*.tar.gz
**/.pytest_cache/

# Runtime data
.landgod-data/
.xclaw-node-data/
managed-client.config.json
managed-client.mcp-servers.json
managed-client-workspace/

# Application specific
.playwright-mcp/
.superpowers/
bin/clawnode.js
bin/clawnode.js.bak

# Logs
*.log

# Test files
test-spawn.js

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/

# Shiproom config (contains team-specific IDs/URLs)
mcp-servers/shiproom-mcp/shiproom-config.yaml

# npm pack output (downloads/ is tracked intentionally)
/*.tgz
